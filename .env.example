# Runtime / deploy configuration (app process + Postgres image init).
# Not a place for local-only docker host port knobs — those are fixed in compose.
#
# Local default path (no .env required):
#   code defaults → localhost + postgres/postgres/yupao_db
#   compose defaults match; app service forces DB_HOST=postgres, REDIS_HOST=redis
#
# Copy when you need real overrides (staging/prod secrets, remote hosts, logging):
#   cp .env.example .env

# --- Database (shared: official Postgres image init + app client) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=yupao_db
DB_HOST=localhost
POSTGRES_PORT=5432

# --- Redis (app client) ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- Logging / process identity (ops) ---
ENV=local
LOG_LEVEL=info
SERVICE_NAME=yupao-api
# LOG_FORMAT=json

# --- Image deploy (optional; compose app service) ---
# APP_IMAGE=ghcr.io/<owner>/<repo>:latest

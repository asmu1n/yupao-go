# Copy to .env and adjust. .env is gitignored.
#
# Variable roles:
# - DB_HOST / REDIS_HOST: where the app process connects
# - POSTGRES_PORT / REDIS_PORT: ports the app uses when connecting
# - *_HOST_PORT: only for docker compose "ports:" host side (local access)
#
# Local (go run + compose dev deps):
#   DB_HOST=localhost  REDIS_HOST=localhost
#   POSTGRES_PORT / REDIS_PORT match the host-mapped ports below
#
# App inside compose (profile full or base-only up):
#   compose injects DB_HOST=postgres, REDIS_HOST=redis, internal ports 5432/6379
#   host .env values for those keys are overridden by compose environment:

# --- Postgres (shared by official image init + app) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=yupao_db

# App → Postgres
DB_HOST=localhost
POSTGRES_PORT=5432

# Host publish (compose dev overlay only)
POSTGRES_HOST_PORT=5432

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Host publish (compose dev overlay only)
REDIS_HOST_PORT=6379

# --- App ---
# Host publish for containerized app
APP_HOST_PORT=8080
# Optional image name when not building locally
# APP_IMAGE=yupao-go:local

# --- Logging (optional) ---
# LOG_LEVEL=debug|info|warn|error
# LOG_FORMAT=text|json
# SERVICE_NAME=yupao-api
# ENV=local|prod
LOG_LEVEL=info
SERVICE_NAME=yupao-api
ENV=local
